PORT=5000
MONGODB_DB_NAME=makeit
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/makeit?retryWrites=true&w=majority
# Direct connection — use if SRV DNS fails on Windows
MONGODB_URI_DIRECT=mongodb://username:password@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/makeit?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173
